NODE_ENV=development
HOST=0.0.0.0
PORT=4000
APP_BASE_URL=http://127.0.0.1:4000
LOG_LEVEL=info
ARTIFACT_STORAGE_PROVIDER=local
ARTIFACT_STORAGE_PATH=./var/artifacts
ARTIFACT_DOWNLOAD_URL_TTL_SECONDS=600
S3_REGION=
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=nexus-artifacts
INTERNAL_SERVICE_TOKENS=[{"id":"local-dev","token":"nexus-local-dev-token","scopes":["internal:read","artifacts:download-url","github:draft"]}]
SLACK_SIGNING_SECRET=replace-me
WEBHOOK_SHARED_SECRET=replace-me
DATABASE_URL=postgres://nexus:nexus@localhost:5432/nexus
REDIS_URL=redis://localhost:6379
GITHUB_DRAFT_SYNC_ENABLED=false
GITHUB_AUTH_MODE=pat
GITHUB_USE_TEST_REPO=false
GITHUB_OWNER=octo-org
GITHUB_REPO=nexus-target
GITHUB_TEST_OWNER=
GITHUB_TEST_REPO=
GITHUB_TOKEN=ghp_replace_me
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
GITHUB_APP_STATE_SECRET=local-github-app-state-secret
PUBLIC_WIDGET_SIGNING_SECRET=local-public-widget-signing-secret
PUBLIC_WIDGET_SESSION_TTL_SECONDS=900
AGENT_EXECUTION_COMMAND=
AGENT_EXECUTION_ARGS=[]
AGENT_EXECUTION_TIMEOUT_SECONDS=600
AGENT_EXECUTION_AUTO_CREATE_PR=false
EXTENSION_MAX_INLINE_ARTIFACT_BYTES=1048576
EXTENSION_MAX_TOTAL_INLINE_ARTIFACT_BYTES=5242880
E2E_BASE_URL=http://127.0.0.1:4000
E2E_AGENT_FIXTURE_BASE_URL=http://127.0.0.1:4000
E2E_TARGET_REPOSITORY=smithdavedesign/testRepo
E2E_ALLOW_PRIMARY_GITHUB_REPO=false