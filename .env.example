NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
ARTIFACT_STORAGE_PROVIDER=local
ARTIFACT_STORAGE_PATH=./var/artifacts
ARTIFACT_DOWNLOAD_URL_TTL_SECONDS=600
S3_REGION=
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=nexus-artifacts
INTERNAL_SERVICE_TOKENS=[{"id":"local-dev","token":"replace-me-service-token","scopes":["internal:read","artifacts:download-url","github:draft"]}]
SLACK_SIGNING_SECRET=replace-me
WEBHOOK_SHARED_SECRET=replace-me
DATABASE_URL=postgres://nexus:nexus@localhost:5432/nexus
REDIS_URL=redis://localhost:6379
GITHUB_DRAFT_SYNC_ENABLED=false
GITHUB_AUTH_MODE=pat
GITHUB_OWNER=octo-org
GITHUB_REPO=nexus-target
GITHUB_TOKEN=ghp_replace_me
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=