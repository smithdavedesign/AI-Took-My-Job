{
  "name": "ai-devops-nexus",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable gateway and control plane for AI-DevOps Nexus.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "e2e:smoke": "tsx src/scripts/e2e/full-stack.ts",
    "e2e:agent-routes": "tsx src/scripts/e2e/agent-execution-routes.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/sensible": "^6.0.3",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "bullmq": "^5.70.4",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.2",
    "playwright-core": "^1.58.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.18.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
