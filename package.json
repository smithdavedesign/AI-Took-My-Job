{
  "name": "ai-devops-nexus",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable gateway and control plane for AI-DevOps Nexus.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "backfill:report-index": "tsx src/scripts/backfill-report-index.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "mcp:dev": "tsx src/mcp/server.ts",
    "mcp:start": "node dist/mcp/server.js",
    "shadow-suite:tick": "tsx src/scripts/shadow-suite-tick.ts",
    "agent:creative-readme": "tsx src/scripts/agents/creative-readme-agent.ts",
    "e2e:smoke": "tsx src/scripts/e2e/full-stack.ts",
    "e2e:agent-routes": "tsx src/scripts/e2e/agent-execution-routes.ts",
    "e2e:customer-handoff": "tsx src/scripts/e2e/customer-handoff.ts",
    "e2e:config-guardrails": "tsx src/scripts/e2e/config-guardrails.ts",
    "e2e:developer-context": "tsx src/scripts/e2e/developer-context.ts",
    "e2e:hosted-feedback-review": "tsx src/scripts/e2e/hosted-feedback-review.ts",
    "e2e:installation-transfer": "tsx src/scripts/e2e/installation-transfer.ts",
    "e2e:learn-behavior": "tsx src/scripts/e2e/learn-behavior.ts",
    "e2e:mcp-developer-context": "tsx src/scripts/e2e/mcp-developer-context.ts",
    "e2e:replay-browser-context": "tsx src/scripts/e2e/replay-browser-context.ts",
    "e2e:review-dashboard-regression": "tsx src/scripts/e2e/review-dashboard-regression.ts",
    "e2e:review-dashboard-promotion": "tsx src/scripts/e2e/review-dashboard-promotion.ts",
    "e2e:policy-review": "tsx src/scripts/e2e/policy-review.ts",
    "e2e:shadow-suite": "tsx src/scripts/e2e/shadow-suite.ts",
    "e2e:promotion-ownership": "tsx src/scripts/e2e/promotion-ownership.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/sensible": "^6.0.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "bullmq": "^5.70.4",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.2",
    "playwright-core": "^1.58.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.18.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
